<?xml version="1.0" encoding="UTF-8"?>
<!--
  manifest.xml — VINTF (Vendor Interface) manifest for AETHER's Android partition.

  This file holds ONLY device-wide VINTF metadata (target-level, kernel,
  sepolicy). Per-HAL <hal> entries are NOT declared here — each HAL service
  module ships its own vintf_fragment via Android.bp, and the build assembles
  the final /vendor/etc/vintf/manifest.xml by merging this base + every
  per-HAL fragment found under /vendor/etc/vintf/manifest/.

  Listing HALs both here AND in vintf_fragments causes checkvintf to fail:
    "HAL X has a conflict: Conflicting FqInstance: ... vs. ..."

  AETHER's HALs (sensors / radio / camera / power / health, plus gralloc,
  drm-clearkey, etc.) are owned by their respective service modules:
    hal/sensors/  -> vintf/aether.sensors@2.1.xml
    hal/radio/    -> vintf/aether.radio@2.0.xml
    hal/camera/   -> vintf/aether.camera@2.7.xml
    hal/power/    -> vintf/aether.power@5.xml
    hal/health/   -> vintf/aether.health@2.1.xml

  Reference: source.android.com/devices/architecture/vintf/objects#device-manifest
-->
<manifest version="3.0" type="device" target-level="6">

    <!-- Device target-level=6 (Android 13 compat). The deprecated HIDL fragments
         (health@2.1, radio@1.6) are kept out of the vendor manifest by removing
         their vintf_fragments entries from Android.bp. -->

    <!-- Kernel: we declare 5.4.0 here for VINTF purposes only; the actual
         binary is dragonboard's android-6.1 Image.gz. checkvintf validates
         (kernel version) <-> (kernel target-level) using AOSP's static table —
         5.4.y permits target-level=5, which satisfies the rule "kernel level
         must not equal device level" (device=6). The runtime kernel version
         is read from /proc/version at boot; this XML value is for build-time
         compat checking only. -->
    <kernel target-level="5" version="5.4.0"/>

    <!-- sepolicy version: AOSP 14 switched to date-based versioning (YYYYMM).
         Must match BOARD_SEPOLICY_VERS computed by build/make/core/config.mk
         from the platform shipping API level. AOSP 14 ships 202404.
         assemble_vintf refuses to reconcile a mismatch between this hardcoded
         value and the BOARD_SEPOLICY_VERS env var. -->
    <sepolicy>
        <version>202404</version>
    </sepolicy>

</manifest>
